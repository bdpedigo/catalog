# PostgreSQL connection URL
DATABASE_URL=postgresql+asyncpg://cave_catalog:cave_catalog@localhost:5432/cave_catalog

# Authentication — disable for local development
AUTH_ENABLED=false

# Required when AUTH_ENABLED=true: URL of the middle_auth instance
# AUTH_SERVICE_URL=https://globalv1.daf-apis.com/auth

# MaterializationEngine URL for source-conditional validation
# MAT_ENGINE_URL=https://minniev1.microns-ept.com/materializationengine

# Display name for this service (used in logs)
SERVICE_NAME=cave-catalog
